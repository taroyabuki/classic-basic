10 FOR Y=0 TO 12
20 W=2
30 IF Y=0 THEN W=1
40 FOR X=-39 TO 39
50 CA=X*0.0458
60 CB=Y*0.08333
70 A=CA
80 B=CB
90 FOR I=0 TO 15
100 T=A*A-B*B+CA
110 B=2*A*B+CB
120 A=T
130 IF A*A+B*B>4 THEN GOTO 200
140 NEXT I
150 SP=SP+W
160 GOTO 300
200 HT=HT+W
210 SU=SU+I*W
220 SV=SV+I*I*W
300 NEXT X
310 NEXT Y
320 PRINT "SPACE";SP
330 PRINT "HITS";HT
340 PRINT "SUM1";SU
350 PRINT "SUM2";SV
360 END
