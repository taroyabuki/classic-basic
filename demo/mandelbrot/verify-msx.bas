10 DEFINT A-Z
20 DIM C(15)
30 FOR Y=0 TO 12
40 W=2:IF Y=0 THEN W=1
50 FOR X=-39 TO 39
60 CA=X*.0458:CB=Y*.08333:A=CA:B=CB
70 FOR I=0 TO 15
80 T=A*A-B*B+CA:B=2*A*B+CB:A=T
90 IF A*A+B*B>4 THEN C(I)=C(I)+W:GOTO 110
100 NEXT I:SP=SP+W
110 NEXT X
120 NEXT Y
130 FOR I=0 TO 15
140 HT=HT+C(I):SU=SU+I*C(I):SV=SV+I*I*C(I)
150 NEXT I
160 IF SP=470 THEN PRINT"SPACE OK":GOTO 180
170 PRINT"SPACE NG";SP
180 IF HT=1505 THEN PRINT"HITS OK":GOTO 200
190 PRINT"HITS NG";HT
200 IF SU=2859 THEN PRINT"SUM1 OK":GOTO 220
210 PRINT"SUM1 NG";SU
220 IF SV=16951 THEN PRINT"SUM2 OK":GOTO 240
230 PRINT"SUM2 NG";SV
240 END
