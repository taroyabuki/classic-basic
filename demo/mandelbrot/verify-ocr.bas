10 CLS
20 FOR Y=0 TO 12
30 W=2
40 IF Y=0 THEN W=1
50 FOR X=-39 TO 39
60 CA=X*0.0458
70 CB=Y*0.08333
80 A=CA
90 B=CB
100 FOR I=0 TO 15
110 T=A*A-B*B+CA
120 B=2*A*B+CB
130 A=T
140 IF A*A+B*B>4 THEN GOTO 200
150 NEXT I
160 SP=SP+W
170 GOTO 300
200 HT=HT+W
210 SU=SU+I*W
220 SV=SV+I*I*W
300 NEXT X
310 NEXT Y
320 CLS
330 IF SP=470 THEN PRINT "SPACE OK":GOTO 350
340 PRINT "SPACE NG";SP
350 IF HT=1505 THEN PRINT "HITS OK":GOTO 370
360 PRINT "HITS NG";HT
370 IF SU=2859 THEN PRINT "SUM1 OK":GOTO 390
380 PRINT "SUM1 NG";SU
390 IF SV=16951 THEN PRINT "SUM2 OK":GOTO 410
400 PRINT "SUM2 NG";SV
410 END
