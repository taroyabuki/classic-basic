10 FOR Y=0 TO 12
20 W=2:IF Y=0 THEN W=1
30 FOR X=-39 TO 39
40 E=X*.0458:F=Y*.08333
50 A=E:B=F
60 FOR I=0 TO 15
70 T=A*A-B*B+E
80 B=2*A*B+F:A=T
90 IF A*A+B*B>4 THEN 130
100 NEXT I
110 SP=SP+W
120 GOTO 160
130 HT=HT+W:SU=SU+I*W
140 SV=SV+I*I*W
160 NEXT X
170 NEXT Y
180 IF SP=470 THEN PRINT"SPACE OK"
190 IF HT=1505 THEN PRINT"HITS OK"
200 IF SU=2859 THEN PRINT"SUM1 OK"
210 IF SV=16951 THEN PRINT"SUM2 OK"
