10 T$="0123456789ABCDEF"
20 FOR Y=-12 TO 12
30 L$=""
40 FOR X=-39 TO 39
50 CA=X*0.0458
60 CB=Y*0.08333
70 A=CA
80 B=CB
90 FOR I=0 TO 15
100 T=A*A-B*B+CA
110 B=2*A*B+CB
120 A=T
130 IF A*A+B*B>4 THEN GOTO 160
140 NEXT I
150 C$=" ":GOTO 170
160 C$=MID$(T$,I+1,1)
170 L$=L$+C$
180 NEXT X
190 PRINT "1"+LEFT$(L$,37)+"|"
200 PRINT "2"+MID$(L$,38,37)+"|"
210 PRINT "3"+MID$(L$,75,5)+"|"
220 NEXT Y
230 END
