10 FOR Y=0 TO 12
20 W=2:IF Y=0 THEN W=1
30 FOR X=-39 TO 39:CA=X*.0458:CB=Y*.08333:A=CA:B=CB
40 FOR I=0 TO 15
50 T=A*A-B*B+CA:B=2*A*B+CB:A=T
60 IF A*A+B*B<=4 THEN 90
70 HT=HT+W:SU=SU+I*W:SV=SV+I*I*W:GOTO 100
90 NEXT I:SP=SP+W
100 NEXT X,Y
110 IF SP=470 THEN PRINT"SPACE OK"
120 IF HT=1505 THEN PRINT"HITS OK"
130 IF SU=2859 THEN PRINT"SUM1 OK"
140 IF SV=16951 THEN PRINT"SUM2 OK"
