10 CLEAR 5000
20 DIM S$(12)
30 T$="0123456789ABCDEF"
40 FOR Y=0 TO 12
50 L$=""
60 FOR X=-39 TO 39
70 CA=X*0.0458
80 CB=Y*0.08333
90 A=CA
100 B=CB
110 FOR I=0 TO 15
120 T=A*A-B*B+CA
130 B=2*A*B+CB
140 A=T
150 IF (A*A+B*B)>4 THEN GOTO 180
160 NEXT I
170 C$=" ":GOTO 190
180 C$=MID$(T$,I+1,1)
190 L$=L$+C$
200 NEXT X
210 S$(Y)=L$
220 NEXT Y
230 FOR Y=12 TO 1 STEP -1
240 PRINT S$(Y)
250 NEXT Y
260 PRINT S$(0)
270 FOR Y=1 TO 12
280 PRINT S$(Y)
290 NEXT Y
300 END
