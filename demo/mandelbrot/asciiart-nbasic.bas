10 FOR Y=-12 TO 12
20 L$=""
30 FOR X=-39 TO 39
40 CA=X*0.0458
50 CB=Y*0.08333
60 A=CA
70 B=CB
80 FOR I=0 TO 15
90 T=A*A-B*B+CA
100 B=2*A*B+CB
110 A=T
120 IF A*A+B*B>4 THEN GOTO 150
130 NEXT I
140 C$=" ":GOTO 220
150 IF I<10 THEN C$=STR$(I):GOTO 220
160 IF I=10 THEN C$="A":GOTO 220
170 IF I=11 THEN C$="B":GOTO 220
180 IF I=12 THEN C$="C":GOTO 220
190 IF I=13 THEN C$="D":GOTO 220
200 IF I=14 THEN C$="E":GOTO 220
210 C$="F"
220 L$=L$+RIGHT$(C$,1)
230 NEXT X
240 PRINT L$
250 NEXT Y
260 END
