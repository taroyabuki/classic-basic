10 FOR Y=-12 TO 12
20 FOR X=-39 TO 39
30 CA=X*0.0458
40 CB=Y*0.08333
50 A=CA
60 B=CB
70 FOR I=0 TO 15
80 T=A*A-B*B+CA
90 B=2*A*B+CB
100 A=T
110 IF A*A+B*B>4 THEN GOTO 200
120 NEXT I
130 PRINT " ";
140 GOTO 210
200 IF I<10 THEN PRINT I;:GOTO 210
201 IF I=10 THEN PRINT "A";:GOTO 210
202 IF I=11 THEN PRINT "B";:GOTO 210
203 IF I=12 THEN PRINT "C";:GOTO 210
204 IF I=13 THEN PRINT "D";:GOTO 210
205 IF I=14 THEN PRINT "E";:GOTO 210
206 PRINT "F";
210 NEXT X
220 PRINT
230 NEXT Y
240 END
