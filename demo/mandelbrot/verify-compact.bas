10 DEFINT A-Z:DIM C(15)
20 FOR Y=0 TO 12:W=2:IF Y=0 THEN W=1
30 FOR X=-39 TO 39:CA=X*.0458:CB=Y*.08333:A=CA:B=CB
40 FOR I=0 TO 15:T=A*A-B*B+CA:B=2*A*B+CB:A=T:IF A*A+B*B>4 THEN C(I)=C(I)+W:GOTO 60
50 NEXT I:SP=SP+W
60 NEXT X,Y
70 HT=0:SU=0:SV=0:FOR I=0 TO 15:HT=HT+C(I):SU=SU+I*C(I):SV=SV+I*I*C(I):NEXT I
80 IF SP=470 THEN PRINT"SPACE OK" ELSE PRINT"SPACE NG";SP
90 IF HT=1505 THEN PRINT"HITS OK" ELSE PRINT"HITS NG";HT
100 IF SU=2859 THEN PRINT"SUM1 OK" ELSE PRINT"SUM1 NG";SU
110 IF SV=16951 THEN PRINT"SUM2 OK" ELSE PRINT"SUM2 NG";SV
