10 FOR Y=0 TO 12
20 W=2:IF Y=0 THEN W=1
30 FOR X=-39 TO 39
40 CA=X*.0458:CB=Y*.08333
50 A=CA:B=CB
60 FOR I=0 TO 15
70 T=A*A-B*B+CA
80 B=2*A*B+CB:A=T
90 IF A*A+B*B>4 THEN 130
100 NEXT I
110 SP=SP+W
120 GOTO 140
130 HT=HT+W:SU=SU+I*W:SV=SV+I*I*W
140 NEXT X
150 NEXT Y
160 CLS
170 IF SP=470 THEN PRINT"SPACE OK"
175 IF SP<>470 THEN PRINT"SPACE NG"
180 IF HT=1505 THEN PRINT"HITS OK"
185 IF HT<>1505 THEN PRINT"HITS NG"
190 IF SU=2859 THEN PRINT"SUM1 OK"
195 IF SU<>2859 THEN PRINT"SUM1 NG"
200 IF SV=16951 THEN PRINT"SUM2 OK"
205 IF SV<>16951 THEN PRINT"SUM2 NG"
210 END
