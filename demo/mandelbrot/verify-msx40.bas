10 DEFINT A-Z
20 DIM C(15)
30 FOR Y=0 TO 12
40 W=2
50 IF Y=0 THEN W=1
60 FOR X=-39 TO 39
70 CA=X*.0458
80 CB=Y*.08333
90 A=CA:B=CB
100 FOR I=0 TO 15
110 T=A*A-B*B+CA
120 B=2*A*B+CB
130 A=T
140 IF A*A+B*B>4 THEN 170
150 NEXT I
160 SP=SP+W
165 GOTO 190
170 C(I)=C(I)+W
190 NEXT X
200 NEXT Y
210 FOR I=0 TO 15
220 HT=HT+C(I)
230 SU=SU+I*C(I)
240 SV=SV+I*I*C(I)
250 NEXT I
260 CLS
270 IF SP=470 THEN PRINT"SPACE OK":GOTO 290
280 PRINT"SPACE NG";SP
290 IF HT=1505 THEN PRINT"HITS OK":GOTO 310
300 PRINT"HITS NG";HT
310 IF SU=2859 THEN PRINT"SUM1 OK":GOTO 330
320 PRINT"SUM1 NG";SU
330 IF SV=16951 THEN PRINT"SUM2 OK":GOTO 350
340 PRINT"SUM2 NG";SV
350 END
