10 FOR Y=0 TO 12
20 W=2
30 IF Y=0 THEN W=1
40 FOR X=-39 TO 39
50 CA=X*.0458
60 CB=Y*.08333
70 A=CA
80 B=CB
90 FOR I=0 TO 15
100 T=A*A-B*B+CA
110 B=2*A*B+CB
120 A=T
130 IF A*A+B*B>4 THEN 200
140 NEXT I
150 SP=SP+W
160 GOTO 240
200 HT=HT+W
210 SU=SU+I*W
220 SV=SV+I*I*W
240 NEXT X
250 NEXT Y
260 IF SP=470 THEN PRINT"SPACE OK"
270 IF HT=1505 THEN PRINT"HITS OK"
280 IF SU=2859 THEN PRINT"SUM1 OK"
290 IF SV=16951 THEN PRINT"SUM2 OK"
