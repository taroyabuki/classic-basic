# Minimal Makefile for test_queue_state
# Avoids SDL2 main.o conflict by linking only necessary objects

CC = gcc
CFLAGS = -O2 -g -Isrc -Isrc/FUNIX -Isrc/SDL2 -Itest_include `./sdl2-config-linux --cflags`
LDFLAGS = `./sdl2-config-linux --libs` -lm

# Core objects needed for state API tests (excluding SDL2/main.o)
CORE_OBJS = \
	obj.sdl2/quasi88.o \
	obj.sdl2/emu.o \
	obj.sdl2/pc88main.o \
	obj.sdl2/memory.o \
	obj.sdl2/status.o \
	obj.sdl2/getconf.o \
	obj.sdl2/crtcdmac.o \
	obj.sdl2/soundbd.o \
	obj.sdl2/pio.o \
	obj.sdl2/intr.o \
	obj.sdl2/pc88sub.o \
	obj.sdl2/fdc.o \
	obj.sdl2/image.o \
	obj.sdl2/monitor.o \
	obj.sdl2/basic.o \
	obj.sdl2/menu.o \
	obj.sdl2/menu-screen.o \
	obj.sdl2/q8tk.o \
	obj.sdl2/q8tk-glib.o \
	obj.sdl2/suspend.o \
	obj.sdl2/keyboard.o \
	obj.sdl2/romaji.o \
	obj.sdl2/pause.o \
	obj.sdl2/z80.o \
	obj.sdl2/z80-debug.o \
	obj.sdl2/snapshot.o \
	obj.sdl2/screen-8bpp.o \
	obj.sdl2/screen-16bpp.o \
	obj.sdl2/screen-32bpp.o \
	obj.sdl2/screen-snapshot.o \
	obj.sdl2/SDL2/graph.o \
	obj.sdl2/SDL2/wait.o \
	obj.sdl2/SDL2/event.o \
	obj.sdl2/FUNIX/file-op.o \
	obj.sdl2/snddrv/quasi88/mame-quasi88.o \
	obj.sdl2/snddrv/quasi88/beepintf.o \
	obj.sdl2/snddrv/quasi88/beep.o \
	obj.sdl2/snddrv/src/driver.o \
	obj.sdl2/snddrv/src/restrack.o \
	obj.sdl2/snddrv/src/sound.o \
	obj.sdl2/snddrv/src/sndintrf.o \
	obj.sdl2/snddrv/src/streams.o \
	obj.sdl2/snddrv/src/sound/flt_vol.o \
	obj.sdl2/snddrv/src/sound/flt_rc.o \
	obj.sdl2/snddrv/src/sound/wavwrite.o \
	obj.sdl2/snddrv/src/sound/2203intf.o \
	obj.sdl2/snddrv/src/sound/2608intf.o \
	obj.sdl2/snddrv/src/sound/ay8910.o \
	obj.sdl2/snddrv/src/sound/fm.o \
	obj.sdl2/snddrv/src/sound/ymdeltat.o \
	obj.sdl2/snddrv/src/sound/samples.o \
	obj.sdl2/snddrv/quasi88/SDL2/audio.o \
	obj.sdl2/snddrv/quasi88/SDL2/sdl2.o \
	obj.sdl2/screen.o

test_queue_state: src/test_queue_state.c $(CORE_OBJS)
	$(CC) $(CFLAGS) -o $@ $(CORE_OBJS) src/test_queue_state.c $(LDFLAGS)

test_runtime_exec_state: src/test_runtime_exec_state.c $(CORE_OBJS)
	$(CC) $(CFLAGS) -o $@ $(CORE_OBJS) src/test_runtime_exec_state.c $(LDFLAGS)

test_exec_transition_runtime: src/test_exec_transition_runtime.c $(CORE_OBJS)
	$(CC) $(CFLAGS) -o $@ $(CORE_OBJS) src/test_exec_transition_runtime.c $(LDFLAGS)

clean:
	rm -f test_queue_state test_runtime_exec_state test_exec_transition_runtime

run: test_queue_state
	./test_queue_state

run_runtime: test_runtime_exec_state
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./test_runtime_exec_state

.PHONY: clean run run_runtime
