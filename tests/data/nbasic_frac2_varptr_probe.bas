100 REM ***** FRACT2 1986.9.1
110  DEFDBL A,D,E,L,M,N,X,Y,Z
120  K=12
130  X=1/5#
140  GOSUB 200
150  Z=Y
160  X=1/239#
170  GOSUB 200
180  A=16*Z-4*Y
190  GOTO 290
200 REM *** arctan
210  Y=0
220  FOR I=K TO 1 STEP -1
230    J=2*I-1
231    DEFDBL P:P=1
232    FOR R=1 TO J
233      P=P*X
234    NEXT R
240    IF I MOD 2=0 GOTO 260
250    Y=Y+P/J:GOTO 270
260    Y=Y-P/J
270  NEXT I
280  RETURN
290 REM ***** Fraction
291  PRINT A
292  PRINT HEX$(PEEK(VARPTR(A)))
